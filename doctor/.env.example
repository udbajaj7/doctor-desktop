# Incue Doctor Desktop — build-time configuration
#
# Flutter reads compile-time configuration via --dart-define, not a runtime .env
# file. This file documents the supported keys and safe placeholder values.
# Do NOT commit real secrets.
#
# Usage:
#   flutter run       --dart-define=INCUE_API_BASE_URL=https://your-api.example.com/
#   flutter build apk --dart-define=INCUE_API_BASE_URL=https://your-api.example.com/
#
# Or with a define file:
#   flutter run --dart-define-from-file=dart_defines.json

# Base URL of the Incue REST API (must be HTTPS and end with a trailing slash).
# When unset, the app falls back to its built-in production default.
INCUE_API_BASE_URL=https://your-api.example.com/
